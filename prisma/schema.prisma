generator client {
  provider = "prisma-client"
  output   = "../../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id @default(cuid()) @db.VarChar(255)
  email         String      @unique @db.VarChar(255)
  password_hash String?     @db.VarChar(255)
  role          String?     @default("CAREGIVER") @db.VarChar(50)
  is_active     Boolean?    @default(true)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  updated_at    DateTime?   @default(now()) @db.Timestamp(6)
  caregivers    Caregiver[]

  @@map("users")
}

model Caregiver {
  id                             String                        @id @default(cuid()) @db.VarChar(255)
  user_id                        String?                       @db.VarChar(255)
  first_name                     String?                       @db.VarChar(255)
  last_name                      String?                       @db.VarChar(255)
  preferred_name                 String?                       @db.VarChar(255)
  phone                          String?                       @db.VarChar(50)
  email                          String?                       @db.VarChar(255)
  gender                         String?                       @db.VarChar(20)
  date_of_birth                  DateTime?                     @db.Date
  city                           String?                       @db.VarChar(100)
  state                          String?                       @db.VarChar(50)
  postal_code                    String?                       @db.VarChar(20)
  address                        String?
  status                         String?                       @default("incomplete") @db.VarChar(50)
  availability_status            String?                       @default("available_now") @db.VarChar(50)
  services                       String[]
  specializations                String[]
  credentials                    String[]
  placement_types                String[]
  willing_live_in                Boolean?                      @default(false)
  willing_overnight              Boolean?                      @default(false)
  has_vehicle                    Boolean?                      @default(false)
  travel_radius                  Int?                          @default(15)
  hourly_rate                    Decimal?                      @db.Decimal(10, 2)
  bio                            String?
  photo_url                      String?
  years_experience               Int?
  rating_count                   Int?                          @default(0)
  aggregate_score                Decimal?                      @default(0) @db.Decimal(3, 2)
  created_at                     DateTime?                     @default(now()) @db.Timestamp(6)
  updated_at                     DateTime?                     @default(now()) @db.Timestamp(6)
  languages                      String[]                      @default([])
  days_available                 String[]                      @default([])
  shift_times                    Json?                         @default("{}")
  open_to_urgent                 Boolean?                      @default(false)
  min_hours_per_week             Int?
  max_hours_per_week             Int?
  holiday_available              Boolean?                      @default(false)
  has_drivers_license            Boolean?                      @default(false)
  willing_client_vehicle         Boolean?                      @default(false)
  transit_accessible             Boolean?                      @default(false)
  willing_to_transport           Boolean?                      @default(false)
  pet_tolerance                  String?                       @default("no_preference") @db.VarChar(50)
  smoker_household               Boolean?                      @default(false)
  technology_comfort             String?                       @default("basic") @db.VarChar(50)
  employment_type                String?                       @default("either") @db.VarChar(50)
  lift_experience                String[]                      @default([])
  medicare_certified             Boolean?                      @default(false)
  vulnerable_sector_check        String?                       @default("not_done") @db.VarChar(50)
  driving_record_check           String?                       @default("not_done") @db.VarChar(50)
  bonded_insured                 Boolean?                      @default(false)
  provincial_registry_number     String?                       @db.VarChar(100)
  job_title                      String?                       @db.VarChar(100)
  clients_served_count           Int?                          @default(0)
  profile_completion_pct         Decimal?                      @default(0) @db.Decimal(5, 2)
  hobbies                        String[]                      @default([])
  dietary_cooking                String[]                      @default([])
  personality_profile            Json?                         @default("{}")
  caregiver_code                 String?                       @unique @db.VarChar(25)
  verify_slug                    String?                       @unique @db.VarChar(5)
  country                        String?                       @default("US") @db.VarChar(2)
  language_fluency               Json?                         @default("{}")
  work_authorisation             Boolean?                      @default(false)
  emergency_contact              Json?                         @default("{}")
  skill_ratings                  Json?                         @default("{}")
  client_types                   String[]                      @default([])
  unwilling_tasks                String[]                      @default([])
  weekly_grid                    Json?                         @default("{}")
  earliest_start_date            DateTime?                     @db.Date
  notice_period                  String?                       @db.VarChar(50)
  preferred_age_group            String?                       @db.VarChar(50)
  preferred_settings             String[]                      @default([])
  hourly_rate_max                Decimal?                      @db.Decimal(8, 2)
  service_areas                  String[]                      @default([])
  education                      Json?                         @default("{}")
  currently_enrolled             Boolean?                      @default(false)
  background_consent             Boolean?                      @default(false)
  background_consent_date        DateTime?                     @db.Timestamptz(6)
  criminal_declaration           Boolean?                      @default(false)
  criminal_declaration_detail    String?
  immunisation_records           Json?                         @default("{}")
  tb_clearance_date              DateTime?                     @db.Date
  declaration_accurate           Boolean?                      @default(false)
  declaration_date               DateTime?                     @db.Timestamptz(6)
  work_history                   Json?                         @default("[]")
  volunteer_experience           Boolean?                      @default(false)
  volunteer_description          String?
  family_care_experience         Boolean?                      @default(false)
  family_care_description        String?
  professional_memberships       String[]                      @default([])
  open_q1                        String?
  open_q2                        String?
  open_q3                        String?
  profile_phase                  Int?                          @default(0)
  certifications                 Json?
  client_preferences             Json?                         @default("{}")
  environment_comfort            Json?                         @default("{}")
  motivation                     Json?                         @default("{}")
  reliability_metrics            Json?                         @default("{}")
  best_fit_profile               Json?                         @default("{}")
  profile_strength_score         Int?                          @default(0)
  // Ghost profile fields
  profile_status                 String?                       @default("unclaimed") @db.VarChar(50)
  claimed                        Boolean?                      @default(false)
  claim_token                    String?                       @unique @db.VarChar(255)
  npi_number                     String?                       @unique @db.VarChar(20)
  license_source                 String?                       @db.VarChar(100)
  verification_tier              Int?                          @default(4)
  agency_caregiver_relationships AgencyCaregiverRelationship[]
  agency_ratings                 AgencyRating[]
  caregiver_certifications       CaregiverCertification[]
  caregiver_references           CaregiverReference[]
  caregiver_shifts               CaregiverShift[]
  users                          User?                         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  airecruit_calls                AIRecruitCall[]

  @@map("caregivers")
}

model CaregiverCertification {
  id            String     @id @default(cuid()) @db.VarChar(255)
  caregiver_id  String?    @db.VarChar(255)
  certification String?    @db.VarChar(255)
  issuing_org   String?    @db.VarChar(255)
  cert_number   String?    @db.VarChar(100)
  issue_date    DateTime?  @db.Date
  expiry_date   DateTime?  @db.Date
  status        String?    @default("active") @db.VarChar(50)
  created_at    DateTime?  @default(now()) @db.Timestamp(6)
  caregivers    Caregiver? @relation(fields: [caregiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("caregiver_certifications")
}

model CaregiverReference {
  id                  String     @id @default(cuid()) @db.VarChar(255)
  caregiver_id        String?    @db.VarChar(255)
  name                String?    @db.VarChar(255)
  relationship        String?    @db.VarChar(100)
  organisation        String?    @db.VarChar(255)
  duration            String?    @db.VarChar(50)
  contact_method      String?    @db.VarChar(50)
  email               String?    @db.VarChar(255)
  phone               String?    @db.VarChar(50)
  created_at          DateTime?  @default(now()) @db.Timestamp(6)
  consent_knows       Boolean?   @default(false)
  consent_agreed      Boolean?   @default(false)
  consent_understands Boolean?   @default(false)
  reference_type      String?    @db.VarChar(50)
  caregivers          Caregiver? @relation(fields: [caregiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("caregiver_references")
}

model Agency {
  id                             String                        @id @default(cuid()) @db.VarChar(255)
  name                           String                        @db.VarChar(255)
  business_type                  String?                       @db.VarChar(100)
  license_number                 String?                       @db.VarChar(100)
  contact_first_name             String?                       @db.VarChar(100)
  contact_last_name              String?                       @db.VarChar(100)
  contact_email                  String?                       @db.VarChar(255)
  contact_phone                  String?                       @db.VarChar(50)
  street                         String?                       @db.VarChar(255)
  city                           String?                       @db.VarChar(100)
  state                          String?                       @db.VarChar(50)
  postal_code                    String?                       @db.VarChar(20)
  status                         String?                       @default("pending") @db.VarChar(50)
  rating_count                   Int?                          @default(0)
  aggregate_score                Decimal?                      @default(0) @db.Decimal(3, 2)
  created_at                     DateTime?                     @default(now()) @db.Timestamp(6)
  updated_at                     DateTime?                     @default(now()) @db.Timestamp(6)
  clerk_user_id                  String?                       @unique @db.VarChar(255)
  vapiAssistantId                String?
  vapiPhoneNumberId              String?
  agency_caregiver_relationships AgencyCaregiverRelationship[]
  agency_ratings                 AgencyRating[]
  agency_saved_searches          AgencySavedSearch[]
  caregiver_shifts               CaregiverShift[]
  airecruit_campaigns            AIRecruitCampaign[]
  airecruit_waitlist             AIRecruitWaitlist[]
  airecruit_suppressions        AIRecruitSuppression[]

  @@map("agencies")
}

model AgencyCaregiverRelationship {
  id                String           @id @default(cuid()) @db.VarChar(255)
  agency_id         String?          @db.VarChar(255)
  caregiver_id      String?          @db.VarChar(255)
  relationship_type String?          @db.VarChar(50)
  status            String?          @default("active") @db.VarChar(50)
  notes             String?
  created_at        DateTime?        @default(now()) @db.Timestamp(6)
  updated_at        DateTime?        @default(now()) @db.Timestamp(6)
  agencies          Agency?          @relation(fields: [agency_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  caregivers        Caregiver?       @relation(fields: [caregiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  caregiver_shifts  CaregiverShift[]

  @@unique([agency_id, caregiver_id])
  @@map("agency_caregiver_relationships")
}

model CaregiverShift {
  id                             String                       @id @default(cuid()) @db.VarChar(255)
  relationship_id                String?                      @db.VarChar(255)
  caregiver_id                   String?                      @db.VarChar(255)
  agency_id                      String?                      @db.VarChar(255)
  date                           DateTime?                    @db.Date
  start_time                     DateTime?                    @db.Time(6)
  end_time                       DateTime?                    @db.Time(6)
  hours                          Decimal?                     @db.Decimal(5, 2)
  status                         String?                      @default("scheduled") @db.VarChar(50)
  notes                          String?
  created_at                     DateTime?                    @default(now()) @db.Timestamp(6)
  agencies                       Agency?                      @relation(fields: [agency_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  caregivers                     Caregiver?                   @relation(fields: [caregiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agency_caregiver_relationships AgencyCaregiverRelationship? @relation(fields: [relationship_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("caregiver_shifts")
}

model AgencyRating {
  id             String     @id @default(cuid()) @db.VarChar(255)
  agency_id      String?    @db.VarChar(255)
  caregiver_id   String?    @db.VarChar(255)
  reliability    Int?
  punctuality    Int?
  warmth         Int?
  dignity        Int?
  hygiene        Int?
  skills_match   Int?
  would_reengage Boolean?
  public_comment String?
  created_at     DateTime?  @default(now()) @db.Timestamp(6)
  agencies       Agency?    @relation(fields: [agency_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  caregivers     Caregiver? @relation(fields: [caregiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("agency_ratings")
}

model AgencySavedSearch {
  id         String    @id @default(cuid()) @db.VarChar(255)
  agency_id  String?   @db.VarChar(255)
  name       String?   @db.VarChar(255)
  filters    Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  agencies   Agency?   @relation(fields: [agency_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("agency_saved_searches")
}

model agency_shortlist {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agency_clerk_id String    @db.VarChar
  caregiver_id    String    @db.VarChar
  notes           String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  @@unique([agency_clerk_id, caregiver_id])
}

model client_needs {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agency_id            String    @db.Uuid
  client_first_name    String?
  client_age           Int?
  primary_condition    String?
  secondary_conditions String[]  @default([])
  mobility_level       String?
  medications_complex  Boolean?  @default(false)
  services_needed      String[]  @default([])
  care_intensity       String?
  placement_type       String?
  hours_per_week       Int?
  start_date           DateTime? @db.Date
  duration_expected    String?
  city                 String?
  state                String?
  postal_code          String?
  pets_present         String[]  @default([])
  smoking_household    Boolean?  @default(false)
  home_condition       String?
  family_dynamics      String?
  language_required    String?
  gender_preference    String?
  cultural_preference  String?
  personality_desired  String[]  @default([])
  hourly_rate_max      Decimal?  @db.Decimal(6, 2)
  status               String?   @default("open")
  matched_caregiver_id String?   @db.Uuid
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)

  @@index([agency_id], map: "idx_client_needs_agency")
  @@index([status], map: "idx_client_needs_status")
}

model match_scores {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caregiver_id              String    @db.Uuid
  client_needs_id           String    @db.Uuid
  overall_score             Int?
  clinical_fit              Int?
  reliability               Int?
  logistics_match           Int?
  personality_compatibility Int?
  cultural_language_fit     Int?
  retention_likelihood      Int?
  environment_fit           Int?
  strong_fits               String[]  @default([])
  gaps                      String[]  @default([])
  created_at                DateTime? @default(now()) @db.Timestamptz(6)

  @@index([caregiver_id], map: "idx_match_scores_caregiver")
  @@index([client_needs_id], map: "idx_match_scores_client")
  @@index([overall_score(sort: Desc)], map: "idx_match_scores_overall")
}

model placement_outcomes {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caregiver_id      String    @db.Uuid
  agency_id         String    @db.Uuid
  client_needs_id   String?   @db.Uuid
  start_date        DateTime? @db.Date
  end_date          DateTime? @db.Date
  duration_days     Int?
  completion_rate   Decimal?  @db.Decimal(4, 3)
  no_show_count     Int?      @default(0)
  reason_ended      String?
  agency_rating     Json?     @default("{}")
  would_place_again Boolean?
  private_notes     String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@index([agency_id], map: "idx_placement_outcomes_agency")
  @@index([caregiver_id], map: "idx_placement_outcomes_caregiver")
}

model AIRecruitCampaign {
  id                  String            @id @default(cuid())
  agencyId            String
  agency              Agency            @relation(fields: [agencyId], references: [id])
  title               String
  roleDescription     String
  screeningQuestions  String[]
  status              String            @default("draft")
  totalCandidates     Int               @default(0)
  callsCompleted      Int               @default(0)
  callsPending        Int               @default(0)
  callsFailed         Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  calls               AIRecruitCall[]

  @@index([agencyId], map: "idx_airecruit_campaign_agency")
}

model AIRecruitCall {
  id              String            @id @default(cuid())
  campaignId      String
  campaign        AIRecruitCampaign @relation(fields: [campaignId], references: [id])
  caregiverId     String?
  caregiver       Caregiver?        @relation(fields: [caregiverId], references: [id])
  status          String            @default("pending")
  phoneNumber     String
  vapiCallId      String?
  transcript     String?
  rawScore        Float?
  scoreBreakdown Json?
  recommendation  String?
  duration        Int?
  startedAt           DateTime?
  completedAt         DateTime?
  candidateName      String?
  callbackRequestedAt String?
  callbackNotes       String?
  callStatus          String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([campaignId], map: "idx_airecruit_call_campaign")
  @@index([caregiverId], map: "idx_airecruit_call_caregiver")
}

model AIRecruitWaitlist {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  email     String
  createdAt DateTime @default(now())

  @@index([agencyId], map: "idx_airecruit_waitlist_agency")
}

model AIRecruitSuppression {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  reason      String
  addedBy     String
  agencyId    String?
  agency      Agency?  @relation(fields: [agencyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
