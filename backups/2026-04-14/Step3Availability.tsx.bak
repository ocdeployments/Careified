'use client';

import { useState, useEffect } from 'react';
import { saveStep3 } from '@/lib/actions/profile';

const DAYS = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
const PLACEMENT_TYPES = ['Full-Time (40+ hours)', 'Part-Time (20-39 hours)', 'Overnight Care', 'Weekend Care', 'Holiday Care', 'Respite Care', 'Short-Term', 'Long-Term', 'One-Time'];
const TIME_SLOTS = ['6:00 AM', '7:00 AM', '8:00 AM', '9:00 AM', '10:00 AM', '11:00 AM', '12:00 PM', '1:00 PM', '2:00 PM', '3:00 PM', '4:00 PM', '5:00 PM', '6:00 PM', '7:00 PM', '8:00 PM', '9:00 PM', '10:00 PM', '11:00 PM'];

interface Step3Props {
  initialData?: {
    availabilityStatus?: string;
    selectedDays?: string[];
    placementTypes?: string[];
    travelRadius?: number;
  };
  onSave: (data: any) => void;
}

export default function Step3Availability({ initialData = {}, onSave }: Step3Props) {
  const [availabilityStatus, setAvailabilityStatus] = useState(initialData.availabilityStatus || '');
  const [selectedDays, setSelectedDays] = useState<string[]>(initialData.selectedDays || []);
  const [placementTypes, setPlacementTypes] = useState<string[]>(initialData.placementTypes || []);
  const [travelRadius, setTravelRadius] = useState(initialData.travelRadius || 15);
  const [saving, setSaving] = useState(false);

  const toggle = (arr: string[], item: string, setter: (v: string[]) => void) => {
    setter(arr.includes(item) ? arr.filter(x => x !== item) : [...arr, item]);
  };

  useEffect(() => {
    setSaving(true);
    saveStep3('', { availabilityStatus, selectedDays, dayTimes: {}, placementTypes, travelRadius });
    setTimeout(() => setSaving(false), 500);
  }, [availabilityStatus, selectedDays, placementTypes, travelRadius]);

  return (
    <div style={{ maxWidth: '900px', margin: '0 auto' }}>
      <h2 style={{ fontSize: '18px', fontWeight: 800, color: '#0D1B3E', marginBottom: '16px' }}>
        When are you available?
      </h2>

      <label style={{ display: 'block', fontSize: '13px', fontWeight: 600, color: '#0D1B3E', marginBottom: '8px' }}>
        Availability Status
      </label>
      <select value={availabilityStatus} onChange={e => setAvailabilityStatus(e.target.value)}
        style={{ width: '100%', padding: '12px', borderRadius: '12px', border: '1px solid #E2E8F0', marginBottom: '24px' }}>
        <option value="">Select status</option>
        <option value="available">Available Now</option>
        <option value="interviewing">Interviewing</option>
        <option value="soon">Available Soon</option>
        <option value="unavailable">Not Currently Available</option>
      </select>

      <label style={{ display: 'block', fontSize: '13px', fontWeight: 600, color: '#0D1B3E', marginBottom: '8px' }}>
        Days Available
      </label>
      <div style={{ display: 'flex', flexWrap: 'wrap', gap: '8px', marginBottom: '24px' }}>
        {DAYS.map(day => (
          <button key={day} onClick={() => toggle(selectedDays, day, setSelectedDays)}
            style={{
              padding: '8px 16px', borderRadius: '8px', fontSize: '12px',
              border: selectedDays.includes(day) ? '2px solid #C9973A' : '2px solid #E2E8F0',
              backgroundColor: selectedDays.includes(day) ? '#FDF6EC' : 'white',
              color: selectedDays.includes(day) ? '#92400E' : '#64748B',
              cursor: 'pointer',
            }}>
            {day}
          </button>
        ))}
      </div>

      <label style={{ display: 'block', fontSize: '13px', fontWeight: 600, color: '#0D1B3E', marginBottom: '8px' }}>
        Preferred Placement Types
      </label>
      <div style={{ display: 'flex', flexWrap: 'wrap', gap: '8px', marginBottom: '24px' }}>
        {PLACEMENT_TYPES.map(type => (
          <button key={type} onClick={() => toggle(placementTypes, type, setPlacementTypes)}
            style={{
              padding: '8px 12px', borderRadius: '8px', fontSize: '12px',
              border: placementTypes.includes(type) ? '2px solid #C9973A' : '2px solid #E2E8F0',
              backgroundColor: placementTypes.includes(type) ? '#FDF6EC' : 'white',
              color: placementTypes.includes(type) ? '#92400E' : '#64748B',
              cursor: 'pointer',
            }}>
            {type}
          </button>
        ))}
      </div>

      <label style={{ display: 'block', fontSize: '13px', fontWeight: 600, color: '#0D1B3E', marginBottom: '8px' }}>
        Travel Radius: {travelRadius} miles
      </label>
      <input type="range" min="5" max="100" value={travelRadius} onChange={e => setTravelRadius(Number(e.target.value))}
        style={{ width: '100%', marginBottom: '24px' }} />

      {saving && <p style={{ fontSize: '12px', color: '#10B981' }}>Saving...</p>}
    </div>
  );
}
